# Environment variables — copy to `.env.local` (never commit secrets)

# Browser API base — same-origin proxy (see next.config.mjs rewrites)
NEXT_PUBLIC_API_URL=/api

# Next.js rewrite target for /api/* → backend (dev default: localhost:4000)
API_PROXY_TARGET=http://localhost:4000

# Server-side RSC fetches hit the API directly (no browser cookies)
API_INTERNAL_URL=http://localhost:4000/api
